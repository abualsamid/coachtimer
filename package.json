{
  "name": "coachtimer",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "wrangler:login": "wrangler login",
    "prewrangler:publish": "test -z \"$(git status --porcelain)\"",
    "wrangler:publish": "wrangler pages deploy . --project-name coachtimer",
    "prewrangler:deploy-create": "test -z \"$(git status --porcelain)\"",
    "wrangler:deploy-create": "wrangler pages deployment create .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.3.3",
    "typescript": "^5.7.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.17",
    "wrangler": "^4.76.0"
  }
}
