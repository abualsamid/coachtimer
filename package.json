{
  "name": "coachtimer",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "live-server --port=5173 --host=127.0.0.1 --no-browser --watch=index.html,styles.css,app.js,src,sw.js",
    "wrangler:login": "wrangler login",
    "prewrangler:publish": "test -z \"$(git status --porcelain)\"",
    "wrangler:publish": "wrangler pages deploy . --project-name coachtimer",
    "prewrangler:deploy-create": "test -z \"$(git status --porcelain)\"",
    "wrangler:deploy-create": "wrangler pages deployment create .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.3.3",
    "live-server": "^1.2.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "wrangler": "^4.35.0"
  }
}
